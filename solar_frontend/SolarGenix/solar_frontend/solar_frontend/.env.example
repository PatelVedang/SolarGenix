# Optional overrides. If omitted, src/api/apiClient.ts uses Vite proxy defaults.
# Default behavior (recommended for ngrok frontend dev):
#   AUTH -> /auth-api  -> proxied to http://localhost:5000
#   PRED -> /prediction-api -> proxied to http://localhost:8000

# VITE_AUTH_BASE_URL=/auth-api
# VITE_PREDICTION_BASE_URL=/prediction-api

# If you expose backend directly with ngrok, set full https URLs instead:
# VITE_AUTH_BASE_URL=https://<your-auth-ngrok-domain>
# VITE_PREDICTION_BASE_URL=https://<your-pred-ngrok-domain>
